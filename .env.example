# =============================================================================
# Digital Twin — environment variables (place at REPO ROOT next to package.json)
# =============================================================================
#
# Setup:
#   1. Copy this file to `.env` in the same folder (Windows: copy .env.example .env)
#   2. Edit values. Restart Terminals after changes (Vite + Flask).
#
# Security: do NOT commit `.env` — it may contain tokens or machine-specific paths.
#
# -----------------------------------------------------------------------------
# Frontend (Vite) — only variables prefixed with VITE_ are exposed to the browser.
# -----------------------------------------------------------------------------
# Leave unset during local dev: the app uses same-origin URLs + Vite proxy to Flask :5000.
# Use when the API runs elsewhere (GitHub Pages + Render, Electron production, etc.):
# VITE_API_URL=https://digital-twin-9czs.onrender.com

# -----------------------------------------------------------------------------
# Flask — ml_server.py (full API + Vision Transformer waste pipeline)
# -----------------------------------------------------------------------------
# Real inference: default ViT (ImageNet) with softmax → six waste categories (see ml/waste_pipeline/).
# After fine-tuning, point to your saved folder or Hub repo (scripts/train_waste_classifier.py --verify_load).
WASTE_BACKBONE=vit
WASTE_MODEL_ID=google/vit-base-patch16-224

# Port for ml_server.py (+ lightweight backend/app.py): Vite proxy expects 5000 unless you change vite.config.js.
PORT=5000

# --- Optional YOLO cues (scene / plastic prior) — see ml.research.yolo_baseline ---
# Requires OpenCV (opencv-python-headless) for material cues.
# WASTE_FRAGMENT_COHESION=true
# WASTE_COHESION_MIXED_MIN_PCT=68
# WASTE_COHESION_WINNER_FLOOR=0.33
# WASTE_COHESION_MARGIN=0.085
# YOLO_WEIGHTS=yolov8n.pt
# YOLO_ENABLED=true               # false to skip Ultralytics inference
# When YOLO sees COCO bottles/cups, shift six-way bins toward Plastic (before organic colour heuristic).
# WASTE_YOLO_PLASTIC_PRIOR=1
# WASTE_YOLO_PLASTIC_MIN_CONF=0.18

# TrashNet-style 6-class Hugging Face heads (cardboard/glass/metal/paper/plastic/trash) have no organic logit.
# Default 0.28 routes 28% of the model's "trash" probability into the Organic bar (display hint only). Set to 0 to disable.
# WASTE_TRASHNET_ORGANIC_SHARE=0.28

# Banana/peel etc.: HSV heuristic re-balances TrashNet logits toward Organic (production = fine-tuned weights).
# WASTE_ORGANIC_VISUAL=1
# WASTE_ORGANIC_VISUAL_MIN_CUE=0.30
# WASTE_ORGANIC_VISUAL_BLEND=0.92
# Skip peel boost when mixed-landfill score >= this (0–1). Higher = stricter (more mixed piles stay mixed).
# WASTE_ORGANIC_MIXED_SUPPRESS=0.52

# Optional: faster HF Hub downloads / higher rate limits (never commit a real token to git).
# HF_TOKEN=
