{
  "name": "digital-twin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "python ml_server.py",
    "dev:api:mock": "python backend/app.py",
    "dev:full": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron electron/main.cjs\"",
    "electron:full": "concurrently -k \"npm run dev:api\" \"npm run electron:dev\"",
    "build": "vite build",
    "build:github": "cross-env GH_PAGES=true vite build",
    "electron:start": "cross-env NODE_ENV=production electron electron/main.cjs",
    "electron:preview": "vite build && npm run electron:start",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "chart.js": "^4.4.8",
    "exifr": "^7.1.3",
    "leaflet": "^1.9.4",
    "leaflet-control-geocoder": "^2.4.0",
    "leaflet.heat": "^0.2.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1"
  }
}
